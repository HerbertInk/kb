# Database — Vercel Postgres (automatically set when you add Vercel Postgres to your project)
DATABASE_URL="postgresql://user:password@host:5432/dbname"
# Or use POSTGRES_PRISMA_URL if set by Vercel automatically

# Lightning Mode: "demo" (simulated) | "blink" (real via Blink)
NEXT_PUBLIC_LN_MODE=demo

# Blink Lightning (https://dashboard.blink.sv to get your keys)
BLINK_API_KEY=your_blink_api_key
BLINK_WALLET_ID=your_blink_wallet_id
BLINK_API_URL=https://api.blink.sv/graphql
